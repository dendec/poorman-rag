# poorman-rag Indexer Sample Configuration

# Storage paths
db_file: "index/dataset.sqlite"
index_file: "index/vectors.usearch"
# target: "path/to/your/files" # Local folder to index
# datasource: "core.datasources.folder.FolderDataSource"

# Model settings
model_name: "intfloat/multilingual-e5-small"
vector_dim: 384
vector_dtype: "f16"
max_tokens: 512
pooling_mode: "mean" # "mean" for BERT/E5, "last" for Qwen/Causal models
prefix: "passage: "
query_prefix: "query: "
compile_model: true

# Chunking settings (In TOKENS)
chunk_size: 400
chunk_overlap: 50

# RRF (Hybrid Search) settings
rrf_k: 60
limit_vector: 20
limit_fts: 20
top_k: 10

# FTS5 settings: "speed" (duplicate data) or "size" (external content)
fts_mode: "speed"

# Indexing batch parameters
batch_size: 32
checkpoint_period: 1000
enable_vector_index: true

# Normalization (optional)
# normalization_mapping:
#   "ё": "е"
# chars_to_remove: "!\"#$%&'()*+,-./:;<=>?@[\\]^_`{|}~"